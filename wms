# Private subcommand: output numbered+formatted item list for fzf
# Each line: <linenum>\t<name> [│ <field>...]  (only non-empty fields included)
function cmd__list_items() {
    awk -F'\t' -v sep=" \033[2m|\033[0m " 'NR > 1 {
        printf "%06d\t", NR - 1
        display = $1
        if ($2 != "") display = display sep $2
        if ($3 != "") display = display sep $3
        if ($4 != "") display = display sep $4
        print display
    }' "$WMS_FILE"
}

# Private subcommand: called by fzf --preview
# Argument is the line number from nl output (1-based data line)
function cmd__preview() {
    local item_num="$1"
    item_num=$((10#$item_num))
    local file_line=$(( item_num + 1 ))
    local raw_line
    raw_line=$(sed -n "${file_line}p" "$WMS_FILE")

    if [[ -z "$raw_line" ]]; then
        print "(item not found)"
        return
    fi

    local item_name item_location item_category item_tags item_notes
    parse_item "$raw_line"

    print -r -- "${C_BOLD}${item_name}${C_RESET}"
    print ""
    print -r -- "${C_CYAN}Location:${C_RESET}  ${item_location:-${C_DIM}(not set)${C_RESET}}"
    print -r -- "${C_CYAN}Category:${C_RESET}  ${item_category:-${C_DIM}(not set)${C_RESET}}"
    print -r -- "${C_CYAN}Tags:${C_RESET}      ${item_tags:-${C_DIM}(none)${C_RESET}}"
    print -r -- "${C_CYAN}Notes:${C_RESET}     ${item_notes:-${C_DIM}(none)${C_RESET}}"
    return 0
}

# Private subcommand: edit a specific line (called from fzf ctrl-e binding)
function cmd__edit_line() {
    local item_num="$1"
    item_num=$((10#$item_num))
    _do_edit "$item_num"
}

# Private subcommand: delete a specific line (called from fzf ctrl-d binding)
function cmd__delete_line() {
    local item_num="$1"
    item_num=$((10#$item_num))
    local file_line=$(( item_num + 1 ))
    local raw_line
    raw_line=$(sed -n "${file_line}p" "$WMS_FILE")

    if [[ -z "$raw_line" ]]; then
        print -u2 "wms: item not found"
        return 1
    fi

    local item_name item_location item_category item_tags item_notes
    parse_item "$raw_line"

    printf "Delete '${item_name}'? [y/N] " >&2
    read -r confirm < /dev/tty
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        backup_data
        local tmpfile
        tmpfile=$(mktemp "$WMS_FILE.XXXXXX")
        sed "${file_line}d" "$WMS_FILE" > "$tmpfile" && mv "$tmpfile" "$WMS_FILE"
        print -r -- "Deleted: $item_name" >&2
    else
        print "Cancelled." >&2
    fi
}

function main() {
    init_data

    local cmd="${1:-search}"
    shift 2>/dev/null || true

    # Commands that require fzf
    case "$cmd" in
        search|s|rm|remove|edit|e)
            check_fzf || exit 1
            ;;
    esac

    case "$cmd" in
        add)            cmd_add "$@" ;;
        search|s)       cmd_search "$@" ;;
        find|f)         cmd_find "$@" ;;
        ls|list)        cmd_ls "$@" ;;
        rm|remove)      cmd_rm "$@" ;;
        edit|e)         cmd_edit "$@" ;;
        install)        cmd_install ;;
        help|-h|--help) cmd_help ;;
        version|-v|--version) print "wms $WMS_VERSION" ;;
        _preview)       cmd__preview "$@" ;;
        _edit_line)     cmd__edit_line "$@" ;;
        _delete_line)   cmd__delete_line "$@" ;;
        _list_items)    cmd__list_items "$@" ;;
        *)              print -u2 "wms: unknown command '$cmd'"; cmd_help; exit 1 ;;
    esac
}

main "$@"
